{
  "name": "poultry-bos",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=counter-app --filter=api",
    "dev:all": "turbo run dev",
    "dev:api": "turbo run dev --filter=api",
    "dev:counter": "turbo run dev --filter=counter-app",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate": "pnpm --filter @repo/database db:generate",
    "db:migrate": "pnpm --filter @repo/database db:migrate",
    "db:seed": "pnpm --filter @repo/database db:seed",
    "db:backfill-product-units": "pnpm --filter @repo/database db:backfill-product-units",
    "db:setup": "pnpm db:migrate && pnpm db:seed"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.18",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.13"
  },
  "dependencies": {
    "lucide-react": "^1.21.0"
  }
}
